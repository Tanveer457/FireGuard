# ─────────────────────────────────────────────
#  FireGuard — Server Config Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in real values (never commit .env!)
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/fire_detection

# Redis
REDIS_URL=redis://:<password>@localhost:6379/0

# Auth tokens (must match edge config.yaml → server.token)
EDGE_TOKEN=your-edge-secret-token-here
DASHBOARD_TOKEN=your-dashboard-secret-token-here

# Storage paths (auto-created on startup)
STORAGE_ROOT=./storage
SNAPSHOTS_DIR=./storage/snapshots
CLIPS_DIR=./storage/clips

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Alert settings
ALERT_RETENTION_DAYS=30
MAX_SNAPSHOT_SIZE_MB=5
